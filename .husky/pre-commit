if command -v npx >/dev/null 2>&1; then
  npx lint-staged
elif [ -x "/mnt/c/Program Files/nodejs/node.exe" ]; then
  # WSL without node on PATH: fall back to the Windows node install
  "/mnt/c/Program Files/nodejs/node.exe" node_modules/lint-staged/bin/lint-staged.js
else
  echo "husky pre-commit: node/npx not found on PATH" >&2
  exit 1
fi
